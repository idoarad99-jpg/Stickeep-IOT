{
  "rules": {
    ".read": false,
    ".write": false,

    "reservations": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('students').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('students').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "seats": {
      ".read": "auth != null",
      "$seatId": {
        ".write": "auth != null"
      }
    },

    "reports": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
